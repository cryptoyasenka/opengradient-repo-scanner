# GitHub API token (optional but recommended — increases rate limit from 60 to 5000 req/hr)
# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# WalletConnect Project ID (required for RainbowKit wallet connection)
# Create at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# App wallet private key for x402 micropayments (optional)
# If set, the app will automatically pay for OpenGradient AI inference using this wallet
# The wallet must hold OPG tokens on Base Sepolia
# Format: 0x + 64 hex chars
APP_WALLET_PRIVATE_KEY=
